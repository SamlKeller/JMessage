                </div>
                <div class="theirMessage msg">
                    <p class="theirMessageP msgp">This is my message</p>
                </div>
                <div class="theirMessage msg">
                    <p class="theirMessageP msgp">This is my message</p>
                </div>
                <div class="myMessage msg">
